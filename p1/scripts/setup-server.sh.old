#!/bin/bash
set -e

echo "=== Setting up K3s Server ==="
echo "Server IP: ${SERVER_IP}"

# Install K3s with proper binding and permissions
curl -sfL https://get.k3s.io | sh -s - server \
  --bind-address ${SERVER_IP} \
  --advertise-address ${SERVER_IP} \
  --node-ip ${SERVER_IP} \
  --flannel-iface eth1 \
  --write-kubeconfig-mode 644

# Wait for K3s to be ready
echo "Waiting for K3s to be ready..."
for i in {1..60}; do
  if [ -f /etc/rancher/k3s/k3s.yaml ]; then
    echo "K3s config file found!"
    break
  fi
  echo "Attempt $i/60: Waiting for k3s.yaml..."
  sleep 2
done

# Fix kubeconfig to use the correct IP
sed -i "s/127.0.0.1/${SERVER_IP}/g" /etc/rancher/k3s/k3s.yaml

# Create .kube directory for vagrant user
mkdir -p /home/vagrant/.kube
cp /etc/rancher/k3s/k3s.yaml /home/vagrant/.kube/config
chown -R vagrant:vagrant /home/vagrant/.kube
chmod 600 /home/vagrant/.kube/config

# Also create for root user
mkdir -p /root/.kube
cp /etc/rancher/k3s/k3s.yaml /root/.kube/config
chmod 600 /root/.kube/config

# Set KUBECONFIG environment variable for all users
echo "export KUBECONFIG=/etc/rancher/k3s/k3s.yaml" >> /etc/profile.d/k3s.sh
echo "alias k='kubectl'" >> /etc/profile.d/k3s.sh

# Save node token for worker
cp /var/lib/rancher/k3s/server/node-token ${TOKEN_FILE}
chmod 644 ${TOKEN_FILE}

echo "=== Server setup complete ==="
echo "Run 'kubectl get nodes' after logging out and back in"
